APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./data/open-intent-router.db
STORAGE_BACKEND=database

REGISTRY_BACKEND=file
REGISTRY_FILE_PATH=./config/agents.example.yaml
REGISTRY_FILE_FALLBACK_ON_EMPTY=false

ROUTER_LLM_PROVIDER=mock
ROUTER_LLM_MODEL=mock-router
ROUTER_LLM_BASE_URL=
ROUTER_LLM_API_KEY=
ROUTER_LLM_TIMEOUT_SECONDS=20

# DeepSeek can be used through the OpenAI-compatible client:
# ROUTER_LLM_PROVIDER=openai_compatible
# ROUTER_LLM_MODEL=deepseek-chat
# ROUTER_LLM_BASE_URL=https://api.deepseek.com
# ROUTER_LLM_API_KEY=sk-...

ROUTE_MODE=route_and_invoke
ADMIN_API_TOKEN=change-me

ROUTER_MAX_HOST_HISTORY_MESSAGES=20
ROUTER_MAX_AGENT_HISTORY_MESSAGES=12
ROUTER_MAX_RECENT_EVENTS=10
ROUTER_MAX_RECENT_RESULTS=5

EVIDENCE_PROVIDER_ENABLED=false
EVIDENCE_FIXED_QUESTIONS_PATH=./config/fixed_questions.example.yaml
